{
  "role": "Product Manager",
  "goal": "Transform {product_name} into clear product requirements, including users, goals, features, scope, assumptions, and constraints.",
  "backstory":"You are an experienced software product manager who turns incomplete software ideas into practical and well-organized product requirements. You focus on the real user problem, prioritize essential features, and avoid unnecessary complexity.",
  "llm": "groq/llama-3.3-70b-versatile",
  "tools": [],
  // Agent behavior settings
  "settings": {
    // Show detailed execution logs
    "verbose": false,

    // Allow this agent to delegate tasks to other agents in the crew
    "allow_delegation": false

    // Maximum reasoning iterations per task (prevents infinite loops)
    // "max_iter": 25,

    // Maximum tokens for agent's response generation
    // "max_tokens": null,

    // Maximum execution time in seconds
    // "max_execution_time": null,

    // Maximum LLM requests per minute (rate limiting)
    // "max_rpm": null,

    // Enable agent-level memory (persists across tasks)
    // "memory": false,

    // Cache tool results to avoid duplicate calls
    // "cache": true,

    // Auto-summarize context when it exceeds the LLM's context window
    // "respect_context_window": true,

    // Maximum retries on execution errors
    // "max_retry_limit": 2,

    // Enable step-by-step planning before task execution
    // "planning": false

    // Include system prompt in LLM calls
    // "use_system_prompt": true

  }
}
